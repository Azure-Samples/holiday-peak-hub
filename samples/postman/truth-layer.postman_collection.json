{
  "info": {
    "_postman_id": "8f5f79ad-4de8-4b8d-9a4f-cf31c6f8a130",
    "name": "Holiday Peak Hub - Truth Layer APIs",
    "description": "Truth-layer API collection organized by service domain. Uses direct service base URLs by default and can be pointed to APIM routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "truth_ingestion_base_url", "value": "http://localhost:8010" },
    { "key": "consistency_base_url", "value": "http://localhost:8011" },
    { "key": "enrichment_base_url", "value": "http://localhost:8012" },
    { "key": "export_base_url", "value": "http://localhost:8013" },
    { "key": "hitl_base_url", "value": "http://localhost:8014" },
    { "key": "crud_base_url", "value": "http://localhost:8000" },
    { "key": "bearer_token", "value": "" },
    { "key": "product_sku", "value": "prd-001" },
    { "key": "product_id", "value": "prd-001" },
    { "key": "job_id", "value": "" },
    { "key": "review_id", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.collectionVariables.get('bearer_token') || '';",
          "if (token.trim()) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "}",
          "pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Ingestion Service",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{truth_ingestion_base_url}}/health" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Ready",
          "request": { "method": "GET", "url": "{{truth_ingestion_base_url}}/ready" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('2xx/503', () => pm.expect([200,503]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "Ingest Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{truth_ingestion_base_url}}/ingest/product",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": {\n    \"id\": \"prd-001\",\n    \"sku\": \"prd-001\",\n    \"title\": \"Trail Running Shoes\",\n    \"brand\": \"PeakSport\",\n    \"category_id\": \"footwear\",\n    \"description\": \"Lightweight trail shoe\",\n    \"images\": [\"https://example.com/shoe.jpg\"]\n  }\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Bulk Ingest",
          "request": {
            "method": "POST",
            "url": "{{truth_ingestion_base_url}}/ingest/bulk",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"products\": [\n    {\"id\": \"prd-101\", \"sku\": \"prd-101\", \"title\": \"Sample One\", \"brand\": \"Demo\"},\n    {\"id\": \"prd-102\", \"sku\": \"prd-102\", \"title\": \"Sample Two\", \"brand\": \"Demo\"}\n  ],\n  \"concurrency\": 5\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Trigger Sync",
          "request": {
            "method": "POST",
            "url": "{{truth_ingestion_base_url}}/ingest/sync",
            "body": { "mode": "raw", "raw": "{\n  \"max_pages\": 2,\n  \"page_size\": 50,\n  \"concurrency\": 5\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('202 accepted', () => pm.expect([200,202]).to.include(pm.response.code));", "const json = pm.response.json(); if (json.job_id) { pm.collectionVariables.set('job_id', json.job_id); }"] } }]
        },
        {
          "name": "Sync Status",
          "request": { "method": "GET", "url": "{{truth_ingestion_base_url}}/ingest/status/{{job_id}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200/404', () => pm.expect([200,404]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "Webhook",
          "request": {
            "method": "POST",
            "url": "{{truth_ingestion_base_url}}/ingest/webhook",
            "body": { "mode": "raw", "raw": "{\n  \"event_type\": \"product.updated\",\n  \"entity_id\": \"prd-001\",\n  \"data\": {\n    \"title\": \"Trail Running Shoes - Updated\"\n  }\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
    {
      "name": "Completeness (Consistency Validation)",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{consistency_base_url}}/health" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Invoke Validation",
          "request": {
            "method": "POST",
            "url": "{{consistency_base_url}}/invoke",
            "body": { "mode": "raw", "raw": "{\n  \"sku\": \"{{product_sku}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
    {
      "name": "Enrichment",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{enrichment_base_url}}/health" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Invoke Enrichment",
          "request": {
            "method": "POST",
            "url": "{{enrichment_base_url}}/invoke",
            "body": { "mode": "raw", "raw": "{\n  \"sku\": \"{{product_sku}}\",\n  \"related_limit\": 4\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
    {
      "name": "HITL Review",
      "item": [
        {
          "name": "Health (planned service)",
          "request": { "method": "GET", "url": "{{hitl_base_url}}/health" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('service may be pending', () => pm.expect([200,404,503]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "Invoke Review Action (planned)",
          "request": {
            "method": "POST",
            "url": "{{hitl_base_url}}/invoke",
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"approve\",\n  \"proposal_id\": \"sample-proposal-001\",\n  \"reviewer\": \"staff-user\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('service may be pending', () => pm.expect([200,404,422,503]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "Fallback: List CRUD Reviews",
          "request": { "method": "GET", "url": "{{crud_base_url}}/api/reviews?product_id={{product_id}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
    {
      "name": "Export",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{export_base_url}}/health" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200/404', () => pm.expect([200,404]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "Invoke ACP Export",
          "request": {
            "method": "POST",
            "url": "{{export_base_url}}/invoke",
            "body": { "mode": "raw", "raw": "{\n  \"sku\": \"{{product_sku}}\",\n  \"availability\": \"in_stock\",\n  \"currency\": \"usd\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200/404', () => pm.expect([200,404]).to.include(pm.response.code));"] } }]
        }
      ]
    },
    {
      "name": "CRUD Endpoints",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{crud_base_url}}/health" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Products",
          "request": { "method": "GET", "url": "{{crud_base_url}}/api/products" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Categories",
          "request": { "method": "GET", "url": "{{crud_base_url}}/api/categories" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "Create Review (auth required)",
          "request": {
            "method": "POST",
            "url": "{{crud_base_url}}/api/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{product_id}}\",\n  \"rating\": 5,\n  \"title\": \"Great Product\",\n  \"comment\": \"Works as expected.\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200/401', () => pm.expect([200,401,403]).to.include(pm.response.code));", "if (pm.response.code === 200) { const json = pm.response.json(); if (json.id) pm.collectionVariables.set('review_id', json.id); }"] } }]
        }
      ]
    }
  ]
}
