<policies>
    <inbound>
        <base />
    </inbound>
    <backend>
        <forward-request timeout="180" buffer-response="false" />
    </backend>
    <outbound>
        <base />
        <set-header name="Cache-Control" exists-action="override">
            <value>no-cache</value>
        </set-header>
        <set-header name="X-Accel-Buffering" exists-action="override">
            <value>no</value>
        </set-header>
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
