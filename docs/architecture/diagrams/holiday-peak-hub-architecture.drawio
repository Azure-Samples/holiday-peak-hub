        <!-- Gateway to Agents Platform -->
        <mxCell id="conn-gw-agents" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#0078D4;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gateway-group" target="agents-platform">
          <mxGeometry relative="1" as="geometry" />
