        <mxCell id="conn-gw-agents-label" value="REST + MCP" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#555;" vertex="1" connectable="0" parent="conn-gw-agents">
          <mxGeometry x="-0.2" relative="1" as="geometry">
