        <mxCell id="conn-agents-azure-label" value="Three-Tier Memory • Event-Driven SAGA • AI Model Inference" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#555;" vertex="1" connectable="0" parent="conn-agents-azure">
