        <!-- Agents to Azure Platform -->
        <mxCell id="conn-agents-azure" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#0078D4;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="agents-platform" target="azure-platform">
