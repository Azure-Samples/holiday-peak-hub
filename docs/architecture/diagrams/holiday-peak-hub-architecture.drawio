        <!-- Azure Platform to Value -->
        <mxCell id="conn-azure-value" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#4CAF50;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="azure-platform" target="value-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ SIDE ANNOTATIONS ============ -->
        <mxCell id="mcp-badge" value="&lt;b&gt;MCP Protocol&lt;/b&gt;&lt;br&gt;Agent-to-Agent&lt;br&gt;Communication" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=15;fillColor=#FFF8E1;strokeColor=#FFC107;fontSize=9;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="20" y="440" width="110" height="70" as="geometry" />
