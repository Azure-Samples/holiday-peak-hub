        <mxCell id="slm-badge" value="&lt;b&gt;SLM-First&lt;/b&gt;&lt;br&gt;Routing&lt;br&gt;Pattern" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=15;fillColor=#FFF8E1;strokeColor=#FFC107;fontSize=9;fontColor=#333;" vertex="1" parent="1">
