        <mxCell id="subtitle" value="Holiday Peak Hub — Event-Driven Stock Monitoring, JIT Replenishment &amp; Alerting" style="text;html=1;fontSize=11;fontStyle=2;fillColor=none;align=center;fontColor=#666666;" vertex="1" parent="1">
