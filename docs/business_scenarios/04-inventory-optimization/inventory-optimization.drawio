        <mxCell id="a4" value="SMS + Teams&#xa;(Ops Manager)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=20;fontSize=10;" vertex="1" parent="pool5">
