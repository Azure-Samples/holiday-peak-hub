        <mxCell id="ha1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool2" source="h1" target="h2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ha2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool2" source="h2" target="h3"><mxGeometry relative="1" as="geometry"/></mxCell>
