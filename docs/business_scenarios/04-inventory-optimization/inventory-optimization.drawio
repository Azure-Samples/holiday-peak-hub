<mxfile host="draw.io" type="device">
  <diagram name="Inventory Optimization BPMN" id="inv-bpmn">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== POOLS ==================== -->

        <mxCell id="pool1" value="Trigger Events" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#FFF3E0;strokeColor=#E65100;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1400" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="pool2" value="Health Check Agent" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="110" width="1400" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="pool3" value="Event Hubs" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#FFF3E0;strokeColor=#E65100;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="260" width="1400" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="pool4" value="JIT Replenishment Agent" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="340" width="1400" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="pool5" value="Alerts &amp; Triggers Agent" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="460" width="1400" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="pool6" value="Checkout Support Agent" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="590" width="1400" height="100" as="geometry"/>
        </mxCell>

        <!-- ==================== TRIGGER EVENTS LANE ==================== -->

        <mxCell id="t1" value="Order&#xa;Created" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=8;" vertex="1" parent="pool1">
          <mxGeometry x="80" y="20" width="40" height="40" as="geometry"/>
