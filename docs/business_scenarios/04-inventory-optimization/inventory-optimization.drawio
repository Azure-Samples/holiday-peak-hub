          <mxGeometry x="85" y="35" width="30" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="h2" value="Update Stock&#xa;Count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool2">
          <mxGeometry x="160" y="25" width="100" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="h3" value="Analyze Demand&#xa;Velocity (AI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool2">
          <mxGeometry x="300" y="25" width="110" height="45" as="geometry"/>
        </mxCell>

        <!-- Gateway: Stock Level Threshold -->
        <mxCell id="h4" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;isMarkerVisible=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="pool2">
          <mxGeometry x="450" y="30" width="40" height="40" as="geometry"/>
