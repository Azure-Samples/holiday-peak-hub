        <mxCell id="csa3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool6" source="cs3" target="cs4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== CROSS-POOL MESSAGE FLOWS ==================== -->

        <!-- Trigger → Health Check -->
        <mxCell id="mf1" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="t1" target="h1">
