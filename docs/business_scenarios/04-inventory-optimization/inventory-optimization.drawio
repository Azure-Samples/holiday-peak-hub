        <mxCell id="ev2" value="inventory&#xa;.critical_stock" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;" vertex="1" parent="pool3">
          <mxGeometry x="700" y="15" width="40" height="40" as="geometry"/>
