        <mxCell id="t2" value="Return&#xa;Approved" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="pool1">
