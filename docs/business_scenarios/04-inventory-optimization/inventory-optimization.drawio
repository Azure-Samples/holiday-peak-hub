        <!-- ==================== JIT REPLENISHMENT AGENT LANE ==================== -->

        <mxCell id="j1" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=catching;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="pool4">
          <mxGeometry x="557" y="20" width="30" height="30" as="geometry"/>
