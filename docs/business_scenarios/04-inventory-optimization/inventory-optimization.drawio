        <mxCell id="t3" value="Stock Level&#xa;Changed" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=8;" vertex="1" parent="pool1">
          <mxGeometry x="280" y="20" width="40" height="40" as="geometry"/>
