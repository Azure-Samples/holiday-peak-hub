          <mxGeometry x="680" y="35" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="p1_t3" value="Provide Tracking&#xa;to Customer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;fontSize=10;" vertex="1" parent="pool1">
