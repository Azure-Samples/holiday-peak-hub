<mxfile host="draw.io" type="device">
  <diagram name="Shipment &amp; Delivery Tracking" id="bpmn-shipment-tracking">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="BPMN: Shipment &amp; Delivery Tracking" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Carrier Selection → ETA Computation → Route Monitoring → Proactive Notification" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="420" y="55" width="560" height="25" as="geometry"/>
        </mxCell>

        <!-- ==================== POOL 1: CRUD Service / Order Events ==================== -->
