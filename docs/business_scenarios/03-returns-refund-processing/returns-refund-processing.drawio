        <!-- ==================== CROSS-POOL MESSAGE FLOWS ==================== -->

        <!-- Customer → CRUD: Request Return -->
        <mxCell id="mf1" value="POST /orders/{id}/return" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#0066CC;fontSize=9;fontColor=#0066CC;" edge="1" parent="1" source="c2" target="s1">
