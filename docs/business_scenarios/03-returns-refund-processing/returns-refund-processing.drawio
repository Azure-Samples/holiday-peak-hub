          <mxGeometry x="195" y="20" width="30" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="r2" value="Fetch Order&#xa;&amp; History" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool4">
          <mxGeometry x="265" y="10" width="100" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="r3" value="AI: Evaluate&#xa;Return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool4">
          <mxGeometry x="400" y="10" width="100" height="45" as="geometry"/>
