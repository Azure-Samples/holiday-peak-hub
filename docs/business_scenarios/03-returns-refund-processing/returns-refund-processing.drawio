        <!-- Event Hub → Inventory Agent -->
        <mxCell id="mf8" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" parent="1" source="e2" target="i1">
          <mxGeometry relative="1" as="geometry"/>
