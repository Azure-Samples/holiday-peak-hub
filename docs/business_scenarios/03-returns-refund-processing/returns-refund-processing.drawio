        <!-- ==================== INVENTORY AGENT LANE ==================== -->

        <mxCell id="i1" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=catching;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="pool5">
