          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Payment → Event Hub: RefundProcessed -->
        <mxCell id="mf12" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" parent="1" source="p5" target="e3">
          <mxGeometry relative="1" as="geometry"/>
