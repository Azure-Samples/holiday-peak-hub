        </mxCell>
        <mxCell id="subtitle" value="Holiday Peak Hub — AI-Evaluated Returns with Event-Driven Fulfillment" style="text;html=1;fontSize=11;fontStyle=2;fillColor=none;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="350" y="705" width="500" height="20" as="geometry"/>
