        <!-- ==================== EVENT HUB LANE ==================== -->

        <!-- Event: OrderCreated -->
        <mxCell id="e1" value="Order&#xa;Created" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=8;" vertex="1" parent="pool3">
          <mxGeometry x="490" y="15" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Event: InventoryReserved -->
        <mxCell id="e2" value="Inventory&#xa;Reserved" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=8;" vertex="1" parent="pool3">
          <mxGeometry x="700" y="15" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Event: PaymentProcessed -->
        <mxCell id="e3" value="Payment&#xa;Processed" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="pool3">
          <mxGeometry x="900" y="15" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Event: PaymentFailed -->
        <mxCell id="e4" value="Payment&#xa;Failed" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;" vertex="1" parent="pool3">
          <mxGeometry x="980" y="15" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Event: ShipmentScheduled -->
        <mxCell id="e5" value="Shipment&#xa;Scheduled" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="pool3">
          <mxGeometry x="1100" y="15" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Event: InventoryReleased -->
        <mxCell id="e6" value="Inventory&#xa;Released" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=throwing;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;" vertex="1" parent="pool3">
          <mxGeometry x="1350" y="15" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- ==================== INVENTORY AGENT LANE ==================== -->

        <!-- Message Catch: OrderCreated -->
        <mxCell id="i1" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=catching;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="pool4">
          <mxGeometry x="495" y="20" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Task: Check Stock -->
        <mxCell id="i2" value="Check Stock&#xa;Availability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool4">
          <mxGeometry x="560" y="10" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- Gateway: Stock Available? -->
        <mxCell id="i3" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;isMarkerVisible=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="pool4">
          <mxGeometry x="695" y="15" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Task: Reserve Stock -->
        <mxCell id="i4" value="Reserve&#xa;Stock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;fontSize=10;" vertex="1" parent="pool4">
          <mxGeometry x="765" y="10" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Reject (insufficient stock) -->
        <mxCell id="i5" value="Reject:&#xa;No Stock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=20;fontSize=10;" vertex="1" parent="pool4">
          <mxGeometry x="765" y="70" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- Compensation: Receive PaymentFailed -->
        <mxCell id="i6" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=catching;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="pool4">
          <mxGeometry x="988" y="65" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Task: Release Stock -->
        <mxCell id="i7" value="Release&#xa;Reserved Stock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=20;fontSize=10;" vertex="1" parent="pool4">
          <mxGeometry x="1060" y="60" width="120" height="45" as="geometry"/>
        </mxCell>

        <!-- Inventory arrows -->
        <mxCell id="ia1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool4" source="i1" target="i2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ia2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool4" source="i2" target="i3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ia3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" parent="pool4" source="i3" target="i4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ia4" value="No" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" parent="pool4" source="i3" target="i5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ia5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool4" source="i6" target="i7"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== PAYMENT SERVICE LANE ==================== -->

        <!-- Message Catch: InventoryReserved -->
        <mxCell id="p1" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=catching;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="pool5">
          <mxGeometry x="708" y="25" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Task: Process Payment -->
