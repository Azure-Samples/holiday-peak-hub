<mxfile host="draw.io" type="device">
  <diagram name="Order-to-Fulfillment BPMN" id="otf-bpmn">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== POOLS ==================== -->

        <!-- Pool: Customer -->
        <mxCell id="pool1" value="Customer" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1540" height="100" as="geometry"/>
        </mxCell>

        <!-- Pool: CRUD Service (Order API) -->
        <mxCell id="pool2" value="CRUD Service" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="120" width="1540" height="110" as="geometry"/>
        </mxCell>

        <!-- Pool: Azure Event Hubs -->
        <mxCell id="pool3" value="Event Hubs" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#FFF3E0;strokeColor=#E65100;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="230" width="1540" height="80" as="geometry"/>
        </mxCell>

        <!-- Pool: Inventory Reservation Agent -->
        <mxCell id="pool4" value="Inventory Agent" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="310" width="1540" height="120" as="geometry"/>
        </mxCell>

        <!-- Pool: Payment Service -->
        <mxCell id="pool5" value="Payment Service" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="430" width="1540" height="120" as="geometry"/>
        </mxCell>

        <!-- Pool: Logistics Carrier Selection Agent -->
        <mxCell id="pool6" value="Logistics Agent" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="550" width="1540" height="120" as="geometry"/>
        </mxCell>

        <!-- Pool: CRM Agent -->
        <mxCell id="pool7" value="CRM Agent" style="shape=mxgraph.bpmn.swimlane;horizontal=0;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="670" width="1540" height="100" as="geometry"/>
        </mxCell>

        <!-- ==================== CUSTOMER LANE ==================== -->

        <!-- Start Event -->
        <mxCell id="c1" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=general;outline=standard;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="pool1">
          <mxGeometry x="60" y="35" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Task: Fill Cart -->
        <mxCell id="c2" value="Browse Products&#xa;&amp; Fill Cart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool1">
          <mxGeometry x="130" y="25" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Submit Order -->
        <mxCell id="c3" value="Submit Order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool1">
          <mxGeometry x="290" y="25" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Receive Confirmation -->
        <mxCell id="c4" value="Receive&#xa;Confirmation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;fontSize=10;" vertex="1" parent="pool1">
          <mxGeometry x="1310" y="25" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- End Event -->
        <mxCell id="c5" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=terminate;outline=end;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="pool1">
          <mxGeometry x="1470" y="35" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Customer arrows -->
        <mxCell id="ca1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool1" source="c1" target="c2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ca2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool1" source="c2" target="c3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ca3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool1" source="c4" target="c5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== CRUD SERVICE LANE ==================== -->

        <!-- Task: Validate Order -->
        <mxCell id="s1" value="Validate&#xa;Order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool2">
          <mxGeometry x="290" y="30" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Create Order Record -->
        <mxCell id="s2" value="Create Order&#xa;Record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool2">
          <mxGeometry x="450" y="30" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Update Order Status -->
        <mxCell id="s3" value="Update Status&#xa;to Processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;fontSize=10;" vertex="1" parent="pool2">
          <mxGeometry x="1150" y="30" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Send Confirmation -->
