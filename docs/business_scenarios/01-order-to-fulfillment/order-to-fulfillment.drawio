          <mxGeometry x="775" y="15" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- Gateway: Payment Success? -->
        <mxCell id="p3" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.rhombusPerimeter;symbol=exclusiveGw;isMarkerVisible=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="pool5">
          <mxGeometry x="908" y="20" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Task: Capture Payment (success) -->
        <mxCell id="p4" value="Capture&#xa;Payment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;fontSize=10;" vertex="1" parent="pool5">
          <mxGeometry x="975" y="5" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- Task: Log Failure -->
        <mxCell id="p5" value="Log Payment&#xa;Failure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=20;fontSize=10;" vertex="1" parent="pool5">
          <mxGeometry x="975" y="65" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- Payment arrows -->
        <mxCell id="pa1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool5" source="p1" target="p2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool5" source="p2" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa3" value="Success" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" parent="pool5" source="p3" target="p4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa4" value="Failure" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" parent="pool5" source="p3" target="p5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== LOGISTICS AGENT LANE ==================== -->

        <!-- Message Catch: PaymentProcessed -->
        <mxCell id="l1" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=catching;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="pool6">
          <mxGeometry x="908" y="25" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Task: Evaluate Carriers -->
        <mxCell id="l2" value="Evaluate&#xa;Carriers (AI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool6">
          <mxGeometry x="975" y="15" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Schedule Shipment -->
        <mxCell id="l3" value="Schedule&#xa;Shipment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=20;fontSize=10;" vertex="1" parent="pool6">
          <mxGeometry x="1120" y="15" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- End Event -->
        <mxCell id="l4" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=terminate;outline=end;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="pool6">
          <mxGeometry x="1270" y="25" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Logistics arrows -->
        <mxCell id="la1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool6" source="l1" target="l2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="la2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool6" source="l2" target="l3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="la3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool6" source="l3" target="l4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== CRM AGENT LANE ==================== -->

        <!-- Message Catch: OrderCreated -->
        <mxCell id="crm1" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=message;outline=catching;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=0;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="pool7">
          <mxGeometry x="495" y="35" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Task: Update Customer Profile -->
        <mxCell id="crm2" value="Update LTV&#xa;&amp; Profile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool7">
          <mxGeometry x="565" y="25" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- Task: Recalculate Segment -->
        <mxCell id="crm3" value="Recalculate&#xa;Segment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=20;fontSize=10;" vertex="1" parent="pool7">
          <mxGeometry x="710" y="25" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- End Event -->
        <mxCell id="crm4" value="" style="shape=mxgraph.bpmn.shape;perimeter=mxPerimeter.ellipsePerimeter;symbol=terminate;outline=end;isLooping=0;isSequential=0;isCompensation=0;isCall=0;isInstantiating=0;isTask=0;isEnd=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="pool7">
          <mxGeometry x="860" y="35" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- CRM arrows -->
        <mxCell id="crma1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool7" source="crm1" target="crm2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="crma2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool7" source="crm2" target="crm3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="crma3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool7" source="crm3" target="crm4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== CROSS-POOL MESSAGE FLOWS ==================== -->

        <!-- Customer → CRUD: Submit Order -->
        <mxCell id="mf1" value="POST /orders" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#0066CC;fontSize=9;fontColor=#0066CC;" edge="1" parent="1" source="c3" target="s1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CRUD → Event Hub: OrderCreated -->
        <mxCell id="mf2" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="s2" target="e1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Event Hub → Inventory: OrderCreated -->
        <mxCell id="mf3" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="e1" target="i1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Event Hub → CRM: OrderCreated -->
        <mxCell id="mf4" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="e1" target="crm1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Inventory → Event Hub: InventoryReserved -->
        <mxCell id="mf5" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="i4" target="e2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Event Hub → Payment: InventoryReserved -->
        <mxCell id="mf6" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" parent="1" source="e2" target="p1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Payment → Event Hub: PaymentProcessed (success) -->
        <mxCell id="mf7" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" parent="1" source="p4" target="e3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Payment → Event Hub: PaymentFailed (failure) -->
        <mxCell id="mf8" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="p5" target="e4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Event Hub → Logistics: PaymentProcessed -->
        <mxCell id="mf9" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" parent="1" source="e3" target="l1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Event Hub → Inventory: PaymentFailed (compensation) -->
        <mxCell id="mf10" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="e4" target="i6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Logistics → Event Hub: ShipmentScheduled -->
        <mxCell id="mf11" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" parent="1" source="l3" target="e5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Event Hub → CRUD: ShipmentScheduled -->
        <mxCell id="mf12" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#82b366;" edge="1" parent="1" source="e5" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Inventory (compensation) → Event Hub: InventoryReleased -->
