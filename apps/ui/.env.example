# ============================================================
# Holiday Peak Hub – UI Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local to source control.
# ============================================================

# ------------------------------------------------------------
# Microsoft Entra ID (Azure AD) – Authentication
# Required for user login via MSAL.
# Leave blank to run in anonymous/guest mode (Entra is optional
# for local development; the UI will log a debug message and
# continue without authentication).
#
# Steps to obtain these values:
#   1. Register an app in Azure Portal → Entra ID → App registrations.
#   2. Copy the "Application (client) ID" → NEXT_PUBLIC_ENTRA_CLIENT_ID.
#   3. Copy the "Directory (tenant) ID"   → NEXT_PUBLIC_ENTRA_TENANT_ID.
#   See docs/implementation/entra-id-setup.md for full instructions.
# ------------------------------------------------------------
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_TENANT_ID=

# ------------------------------------------------------------
# Backend API URLs
# NEXT_PUBLIC_CRUD_API_URL  – Base URL for the CRUD/REST service.
# NEXT_PUBLIC_AGENT_API_URL – Base URL for the Agent service
#                             (falls back to <CRUD_URL>/agents when unset).
# ------------------------------------------------------------
NEXT_PUBLIC_CRUD_API_URL=http://localhost:8000
NEXT_PUBLIC_AGENT_API_URL=
